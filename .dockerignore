# Reduce submodule context sent to the Docker daemon. The upstream repo ships
# large asset folders and its own git metadata which are unnecessary for
# installing the `indextts` Python package.
index-tts/.git/
index-tts/.github/
index-tts/.venv/
index-tts/archive/
index-tts/assets/
index-tts/checkpoints/
index-tts/docs/
